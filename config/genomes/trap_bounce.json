  "mixing_guidelines": {
    "kick": {
      "samples": ["punchy_kick_bounce", "808_sub_bounce"],
      "compression": "moderate",
      "saturation": "light",
      "notes": "Bouncy but clear. Two-layer for depth without harshness"
    },
    "bass": {
      "samples": ["bouncy_808", "deep_bounce_bass"],
      "compression": "light",
      "saturation": "moderate",
      "notes": "Rolling bass with movement and groove. Melodic elements"
    },
    "snare": {
      "samples": ["crisp_snare_bounce", "layered_clap"],
      "compression": "moderate",
      "saturation": "light",
      "notes": "Punchy with natural feel due to swing"
    },
    "hi_hat": {
      "samples": ["open_hat_swing", "closed_hat_shuffle"],
      "compression": "none",
      "saturation": "none",
      "notes": "Bright, open hats with swing feel. Lots of movement"
    },
    "melody": {
      "samples": ["perky_preset_bell", "bouncy_synth_lead"],
      "compression": "light",
      "saturation": "moderate",
      "notes": "Bright, cheerful melody. Can be cheesy if overdone"
    }
  },
