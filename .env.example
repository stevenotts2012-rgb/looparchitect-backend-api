# ========================================
# LoopArchitect Backend — Environment Configuration
# ========================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
#
# ── LOCAL DEV QUICK START ───────────────────────────────────────────────────
#  Canonical local URLs (keep these consistent across all services):
#    Backend API : http://localhost:8000
#    Frontend    : http://localhost:3000
#
#  Restart commands:
#    Backend  : uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
#    Worker   : python -m app.workers.main
#              (or let the embedded worker handle it — see below)
#    Frontend : cd looparchitect-frontend && npm run dev
#              (runs on http://localhost:3000 by default)
#
#  Local dev uses the Next.js catch-all proxy — the browser only talks to
#  the frontend (port 3000); the proxy forwards /api/... to the backend
#  (port 8000) server-side.  Do NOT set NEXT_PUBLIC_API_URL in local dev.
# ────────────────────────────────────────────────────────────────────────────

# ========================================
# Application Settings
# ========================================
ENVIRONMENT=development
# Set to 'production' on Railway/Render/etc.
DEBUG=false

# ========================================
# Database
# ========================================
# Local dev uses SQLite by default — no DATABASE_URL needed.
# Uncomment and fill in to use PostgreSQL locally:
# DATABASE_URL=postgresql://user:password@localhost/looparchitect
#
# On Railway/Render: DATABASE_URL is provided automatically.

# ========================================
# Redis Queue (RQ for async render jobs)
# ========================================
# Canonical local Redis URL — use 127.0.0.1 (not 'localhost') to avoid IPv6 issues.
REDIS_URL=redis://127.0.0.1:6379/0
# On Railway/Render: REDIS_URL is provided automatically.
# Format: redis://username:password@host:port/db

# ========================================
# Worker Configuration
# ========================================
# ENABLE_EMBEDDED_RQ_WORKER controls whether the web process also runs
# background job workers in-process (default: false — production-safe).
#
# LOCAL DEV (single-process, no separate worker needed):
#   ENABLE_EMBEDDED_RQ_WORKER=true
#   The web process runs both the API and embedded RQ workers.
#   No separate `python -m app.workers.main` process is required.
#
# PRODUCTION (recommended — dedicated worker process):
#   Leave ENABLE_EMBEDDED_RQ_WORKER unset or set to false on the web service.
#   Run `python -m app.workers.main` as a separate worker service.
#   The web process handles API only; the worker handles async jobs.
#   This prevents double-processing and keeps concerns cleanly separated.
#
ENABLE_EMBEDDED_RQ_WORKER=true
EMBEDDED_RQ_WORKER_COUNT=2

# ========================================
# Storage Backend
# ========================================
STORAGE_BACKEND=local
# Options: 'local' (development) or 's3' (production).
# In production, omit this to auto-select 's3' when S3 vars are present.

# ========================================
# AWS S3 Configuration (production only)
# ========================================
# Leave these commented out for local dev — they are only required when
# STORAGE_BACKEND=s3 or when ENVIRONMENT=production and S3 vars are present.
# Uncomment and fill in real values for S3 use:
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=my-looparchitect-bucket
# S3_BUCKET_NAME=my-looparchitect-bucket
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_PUBLIC_BASE_URL=

# ========================================
# CORS & Frontend Configuration
# ========================================
# FRONTEND_ORIGIN — production frontend URL (Railway/Vercel deployment).
# In local dev this is not needed; http://localhost:3000 is always allowed.
# Example: FRONTEND_ORIGIN=https://looparchitect-frontend.vercel.app
FRONTEND_ORIGIN=

# CORS_ALLOWED_ORIGINS — comma-separated extra origins (production only).
# Local-dev origins (localhost:3000 / 127.0.0.1:3000 / localhost:5173) are
# always allowed by the backend regardless of this variable.
# Example: CORS_ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourapp.railway.app
CORS_ALLOWED_ORIGINS=

# Canonical backend base URL (used internally / for self-referencing links).
API_BASE_URL=http://localhost:8000

# ========================================
# Demucs Stem Separation Configuration
# ========================================
# DEMUCS_MODEL — model used when running Demucs separation.
#   Valid values: htdemucs (4-stem) | htdemucs_6s (6-stem, higher quality)
#   Default: htdemucs
# DEMUCS_MODEL=htdemucs

# DEMUCS_TIMEOUT — maximum seconds to wait for a Demucs run (default: 300).
# DEMUCS_TIMEOUT=300

# ========================================
# Stem Separator Provider
# ========================================
# STEM_SEPARATOR_PROVIDER — selects the primary stem separation provider.
#   Valid values: demucs (default) | audioshake
#   When set to "audioshake" and AUDIOSHAKE_API_KEY is present, AudioShake
#   is used with automatic fallback to Demucs on failure.
# STEM_SEPARATOR_PROVIDER=demucs

# AUDIOSHAKE_API_KEY — API key for the AudioShake stem separation service.
#   Required when STEM_SEPARATOR_PROVIDER=audioshake.
# AUDIOSHAKE_API_KEY=


# Phase 1: Producer Engine V2 — deterministic section planning with decision log
# Set to true to enable the new producer plan builder alongside the legacy engine.
# When enabled, API responses include producer_plan, section_summary, decision_log,
# quality_score, and producer_notes fields.
# Default: false (legacy engine only)
PRODUCER_ENGINE_V2=false

# Phase 4: AI Co-Producer Assist — AI suggests, rules validate, engine executes
# Requires OPENAI_API_KEY to be set. Falls back gracefully when AI is unavailable.
# Default: false
AI_PRODUCER_ASSIST=false

# Phase 4: AI Style Interpretation — style-specific AI reasoning for arrangement
# Extends AI_PRODUCER_ASSIST with deeper style interpretation.
# Default: false
AI_STYLE_INTERPRETATION=false
