# ========================================
# LoopArchitect Environment Configuration
# ========================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ========================================
# Application Settings
# ========================================
ENVIRONMENT=development
# Set to 'production' on Railway
DEBUG=false
# Set to 'true' for local development only

# ========================================
# Database (PostgreSQL)
# ========================================
DATABASE_URL=postgresql://user:password@localhost/looparchitect
# On Railway: Use DATABASE_URL provided automatically

# ========================================
# Redis Queue (RQ for async render jobs)
# ========================================
REDIS_URL=redis://localhost:6379/0
# On Railway: Use REDIS_URL provided automatically
# Format: redis://username:password@host:port/db

# ========================================
# Storage Backend Configuration
# ========================================
STORAGE_BACKEND=local
# Options: 'local' (development) or 's3' (production)
# In production with S3 vars set, auto-selects S3

# ========================================
# AWS S3 Configuration (if using S3 storage)
# ========================================
# Set these only if STORAGE_BACKEND=s3 or using production
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_BASE_URL=
# Note: S3 is required on Railway; use Railway IAM role or explicit keys

# ========================================
# CORS & Frontend Configuration
# ========================================
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
API_BASE_URL=http://localhost:8000
# On Railway: Set to the deployed frontend URL
# Example: https://web-production-3afc5.up.railway.app
# Can be comma-separated for multiple origins
