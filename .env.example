# ========================================
# LoopArchitect Backend — Environment Configuration
# ========================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
#
# ── LOCAL DEV QUICK START ───────────────────────────────────────────────────
#  Canonical local URLs (keep these consistent across all services):
#    Backend API : http://localhost:8000
#    Frontend    : http://localhost:3000
#
#  Restart commands:
#    Backend  : uvicorn main:app --reload --host 127.0.0.1 --port 8000
#    Worker   : rq worker --url redis://localhost:6379/0
#    Frontend : cd looparchitect-frontend && npm run dev
#              (runs on http://localhost:3000 by default)
#
#  Local dev uses the Next.js catch-all proxy — the browser only talks to
#  the frontend (port 3000); the proxy forwards /api/... to the backend
#  (port 8000) server-side.  Do NOT set NEXT_PUBLIC_API_URL in local dev.
# ────────────────────────────────────────────────────────────────────────────

# ========================================
# Application Settings
# ========================================
ENVIRONMENT=development
# Set to 'production' on Railway
DEBUG=false

# ========================================
# Database
# ========================================
# Local dev uses SQLite by default (no DATABASE_URL needed).
# Uncomment and fill in to use PostgreSQL locally:
# DATABASE_URL=postgresql://user:password@localhost/looparchitect
#
# On Railway: DATABASE_URL is provided automatically.

# ========================================
# Redis Queue (RQ for async render jobs)
# ========================================
# Canonical local Redis URL:
REDIS_URL=redis://localhost:6379/0
# On Railway: REDIS_URL is provided automatically.
# Format: redis://username:password@host:port/db

# ========================================
# Storage Backend
# ========================================
STORAGE_BACKEND=local
# Options: 'local' (development) or 's3' (production).
# In production with S3 vars present, auto-selects 's3'.

# ========================================
# AWS S3 Configuration (production only)
# ========================================
# Leave blank for local dev (STORAGE_BACKEND=local does not need these).
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_BASE_URL=

# ========================================
# CORS & Frontend Configuration
# ========================================
# FRONTEND_ORIGIN — production frontend URL (Railway/Vercel deployment).
# In local dev this is not needed; http://localhost:3000 is always allowed.
# Example: FRONTEND_ORIGIN=https://looparchitect-frontend.vercel.app
FRONTEND_ORIGIN=

# CORS_ALLOWED_ORIGINS — comma-separated extra origins (production only).
# Local-dev origins (localhost:3000 / 127.0.0.1:3000 / localhost:5173) are
# always allowed by the backend regardless of this variable.
# Example: CORS_ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourapp.railway.app
CORS_ALLOWED_ORIGINS=

# Canonical backend base URL (used internally / for self-referencing links).
API_BASE_URL=http://localhost:8000
