# ========================================
# LoopArchitect Backend — Production Environment Variables
# ========================================
# Set these in your platform's environment variable dashboard
# (Railway Variables, Render Environment, etc.).
# NEVER commit real secrets to version control.
#
# ── HOW TO USE ──────────────────────────────────────────────────────────────
#  1. Copy this file for reference — do not use it as an actual .env file.
#  2. Add each variable to your deployment platform's secrets/env section.
#  3. Platform-managed variables (DATABASE_URL, REDIS_URL on Railway) are
#     injected automatically — no action needed for those.
# ────────────────────────────────────────────────────────────────────────────
#
# ── DEPLOYMENT TOPOLOGY ─────────────────────────────────────────────────────
#
#  Service           | Process
#  ──────────────────────────────────────────────────────────────────────────
#  web               | uvicorn app.main:app --host 0.0.0.0 --port $PORT
#  worker (optional) | python -m app.workers.main
#  Redis             | managed (Railway/Render/Upstash)
#  PostgreSQL        | managed (Railway/Render/Supabase)
#  S3 / R2 storage   | AWS S3 or Cloudflare R2
#
#  Single-process (default):
#    Only the `web` service runs.  ENABLE_EMBEDDED_RQ_WORKER=true (default)
#    makes the web process also run embedded RQ workers.
#
#  Two-process (recommended for production scale):
#    web:    ENABLE_EMBEDDED_RQ_WORKER=false  (API only — no double-processing)
#    worker: python -m app.workers.main       (dedicated job processor)
#
# ────────────────────────────────────────────────────────────────────────────

# ========================================
# Application Settings
# ========================================
ENVIRONMENT=production
DEBUG=false

# ========================================
# Database  (provided automatically by Railway/Render)
# ========================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ========================================
# Redis  (provided automatically by Railway/Render)
# ========================================
REDIS_URL=redis://:password@host:6379/0

# ========================================
# Worker Configuration
# ========================================
# Single-process deployment (web handles both API and jobs):
ENABLE_EMBEDDED_RQ_WORKER=true
EMBEDDED_RQ_WORKER_COUNT=2

# Two-process deployment (set on the `web` service; run a separate `worker`):
# ENABLE_EMBEDDED_RQ_WORKER=false

# ========================================
# Storage Backend
# ========================================
# Omit STORAGE_BACKEND to auto-select 's3' when S3 vars below are present.
# Or set explicitly:
STORAGE_BACKEND=s3

# ========================================
# AWS S3 Configuration
# ========================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=my-looparchitect-production-bucket
# S3_BUCKET_NAME is an alias for AWS_S3_BUCKET — set one or both.
S3_BUCKET_NAME=my-looparchitect-production-bucket
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Optional: public CDN/S3 base URL for generated file links.
S3_PUBLIC_BASE_URL=https://my-looparchitect-production-bucket.s3.amazonaws.com

# ========================================
# CORS & Frontend Configuration
# ========================================
# Set to the URL of your deployed frontend so the backend allows it through CORS.
# Comma-separate multiple origins if needed.
FRONTEND_ORIGIN=https://looparchitect-frontend.vercel.app
# CORS_ALLOWED_ORIGINS=https://looparchitect-frontend.vercel.app,https://alt-origin.example.com

# ========================================
# OpenAPI / Swagger UI — Production server URL
# ========================================
# Railway injects RAILWAY_PUBLIC_DOMAIN automatically (e.g. api-xxx.up.railway.app).
# Render injects RENDER_EXTERNAL_URL automatically.
# These are used only to populate the Swagger UI server dropdown.
# RAILWAY_PUBLIC_DOMAIN=api-xxx.up.railway.app   ← set by Railway automatically
# RENDER_EXTERNAL_URL=https://api-xxx.onrender.com  ← set by Render automatically

# ========================================
# Optional: LLM / Style Engine
# ========================================
# OPENAI_API_KEY=sk-...
# FEATURE_LLM_STYLE_PARSING=true
# OPENAI_MODEL=gpt-4o

# ========================================
# Optional: Tuning
# ========================================
# RENDER_JOB_TIMEOUT_SECONDS=900
