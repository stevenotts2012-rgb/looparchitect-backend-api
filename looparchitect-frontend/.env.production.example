# ========================================
# LoopArchitect Frontend — Production Environment
# ========================================
# Copy this file to .env.production and adjust if needed.
# .env.production is gitignored — set these variables in your hosting
# platform's environment settings (Railway, Vercel, etc.) instead.
#
# ── PRODUCTION QUICK START ──────────────────────────────────────────────────
#  Backend API (Railway): https://web-production-3afc5.up.railway.app
#
#  Request routing in production:
#    browser → NEXT_PUBLIC_API_URL/api/v1/... (absolute URL, direct to backend)
#           → FastAPI at https://web-production-3afc5.up.railway.app/api/v1/...
#
#  The Next.js proxy is still active in production, but when NEXT_PUBLIC_API_URL
#  is set the API client calls the backend directly (no proxy hop).
#  BACKEND_ORIGIN is used by the proxy for any server-side requests.
# ────────────────────────────────────────────────────────────────────────────

# ─── Client-side API base URL ────────────────────────────────────────────────
# Sent to the browser — must be the full public backend URL.
NEXT_PUBLIC_API_URL=https://web-production-3afc5.up.railway.app

# ─── Server-side proxy target ────────────────────────────────────────────────
# Used ONLY by the Next.js proxy (src/app/api/[...path]/route.ts).
# Never exposed to the browser.
BACKEND_ORIGIN=https://web-production-3afc5.up.railway.app
