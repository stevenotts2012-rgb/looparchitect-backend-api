# ========================================
# LoopArchitect Frontend — Local Dev Environment
# ========================================
# Copy this file to .env.local and adjust if needed.
# NEVER commit .env.local to version control.
#
# ── LOCAL DEV QUICK START ───────────────────────────────────────────────────
#  Canonical local URLs:
#    Frontend (this app) : http://localhost:3000
#    Backend API         : http://localhost:8000
#
#  Restart commands:
#    Frontend : npm run dev        (http://localhost:3000)
#    Backend  : uvicorn main:app --reload --host 127.0.0.1 --port 8000
#    Worker   : rq worker --url redis://localhost:6379/0
#               (run from the looparchitect-backend-api directory)
#
#  Request routing in local dev:
#    browser → /api/v1/... (relative URL)
#           → Next.js catch-all proxy (src/app/api/[...path]/route.ts)
#           → FastAPI at http://localhost:8000/api/v1/...
#
#  This proxy-based approach means:
#    - No CORS issues (browser only talks to the Next.js origin)
#    - Multipart file uploads work reliably
#    - NEXT_PUBLIC_API_URL must be UNSET (empty) in local dev
# ────────────────────────────────────────────────────────────────────────────

# ─── Server-side proxy target ────────────────────────────────────────────────
# BACKEND_ORIGIN is used ONLY by the Next.js proxy (src/app/api/[...path]/route.ts).
# It is never exposed to the browser.
# Canonical local backend URL — must match where uvicorn is listening.
BACKEND_ORIGIN=http://localhost:8000

# ─── Client-side API base URL ────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL controls where the browser sends API requests directly.
#
# LOCAL DEV: Leave this UNSET (commented out).  The API client falls back to
# an empty string, which makes fetch use relative URLs (/api/v1/...) that are
# forwarded to the backend by the Next.js proxy above.
#
# PRODUCTION: Set to the deployed backend origin so the browser calls it
# directly (no proxy needed).
# Example: NEXT_PUBLIC_API_URL=https://api-production-xxx.up.railway.app
#
# NEXT_PUBLIC_API_URL=
