{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Dev Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "FastAPI: Dev Server (root main.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "RQ Worker",
      "type": "debugpy",
      "request": "launch",
      "module": "app.workers.main",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "pytest: All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "pytest: Current File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false
    }
  ]
}
